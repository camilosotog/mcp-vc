{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "esModuleInterop": true,
    "strict": true,
    "lib": ["ES2022"],
    "outDir": "./",
    "rootDir": "./",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"]
}
